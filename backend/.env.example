# ============================================
# CONFIGURACION DEL SERVIDOR
# ============================================
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://tu-app.vercel.app

# ============================================
# SUPABASE (datos estructurados: votos, actas_metadata)
# ============================================
# Lo obtienes en: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# MONGODB ATLAS (datos semiestructurados: reportes_acta, logs_eventos)
# ============================================
# Lo obtienes en: Atlas > Connect > Drivers > Connection String
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=elecciones2026

# ============================================
# BACKBLAZE B2 (archivos no estructurados: PDFs, imagenes, logs)
# B2 expone una API compatible con S3
# Lo obtienes en: B2 Dashboard > Application Keys
# ============================================
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET_NAME=elecciones2026-actas
B2_KEY_ID=0040xxxxxxxxxxxxxxxxxxx
B2_APPLICATION_KEY=K004xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SEGURIDAD
# ============================================
# Token simple para proteger endpoints administrativos (opcional, ver docs)
ADMIN_TOKEN=cambia-esto-por-un-valor-secreto-largo
